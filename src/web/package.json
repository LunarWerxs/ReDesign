{
  "name": "reimagine-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:i18n && vite build",
    "//typecheck": "tsconfig.app.json covers src/ only, so the test/ specs need the second pass or they rot untyped.",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && vue-tsc --noEmit -p tsconfig.vitest.json",
    "check:i18n": "node scripts/i18n-check.mjs",
    "preview": "vite preview",
    "//test": "Vitest, run via `npm run test`. NOT `bun test`: bun's runner has no Vue SFC compiler, so .vue imports resolve to a string path and @vue/test-utils throws a WeakMap key error. CI uses `npm run test` for the same reason.",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formkit/drag-and-drop": "^0.6.1",
    "@lucide/vue": "^1.23.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.39",
    "vue-i18n": "^11",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  }
}
