# =============================================================================
#  Reimagine — API key pools  (TEMPLATE — copy to .env and fill in)
# -----------------------------------------------------------------------------
#  Each <PROVIDER>_API_KEYS is a comma-separated pool of keys. The key manager
#  round-robins through the pool, tracks per-key health, and automatically
#  cools down keys that rate-limit, exhaust balance, or fail auth.
#
#  Indexed form also works and is merged in:
#      OPENAI_API_KEYS_1=sk-...
#      OPENAI_API_KEYS_2=sk-...
# =============================================================================

# Claude Opus 4.8  -> claude-opus-4-8  (https://api.anthropic.com/v1)
ANTHROPIC_API_KEYS=sk-ant-api03-xxxx,sk-ant-api03-yyyy

# GPT 5.5  -> gpt-5.5  (https://api.openai.com/v1)  [uses max_completion_tokens]
OPENAI_API_KEYS=sk-proj-xxxx,sk-proj-yyyy

# DeepSeek V4 Pro  -> deepseek-v4-pro  (https://api.deepseek.com/v1)
DEEPSEEK_API_KEYS=sk-xxxx,sk-yyyy

# Gemini 3.5 Flash  -> gemini-3.5-flash  (generativelanguage.googleapis.com)
GEMINI_FLASH_API_KEYS=AIza-xxxx,AIza-yyyy

# Gemini 3.1 Pro  -> gemini-3.1-pro-preview  (generativelanguage.googleapis.com)
GEMINI_PRO_API_KEYS=AIza-xxxx,AIza-yyyy

# Qwen 3.5 Plus  -> qwen3.5-plus  (dashscope.aliyuncs.com/compatible-mode/v1)
QWEN_API_KEYS=sk-xxxx,sk-yyyy

# Muse Spark 1.1  -> muse-spark-1.1  (https://api.meta.ai/v1, OpenAI-compatible)
#   Meta AI key format: LLM_<16-digit app_id>_<secret>
METAAI_API_KEYS=LLM_xxxx,LLM_yyyy

# ─── Advanced (optional) ─────────────────────────────────────────────
# You do NOT need to set any of these to get started — each already has a
# sensible default baked into the code. Uncomment only to override.
#
# PORT=5178                     # HTTP port for the local server/viewer
# MAX_CONCURRENCY=12            # max in-flight model jobs
# MAX_POOL_CONCURRENCY=4        # max concurrent requests per key pool
# COOLDOWN_RATE_LIMIT_SEC=60    # backoff after a provider rate-limit (429)
# COOLDOWN_NO_BALANCE_SEC=3600  # backoff after an out-of-balance error
# COOLDOWN_DEAD_SEC=86400       # backoff after a key looks dead
# REQUEST_TIMEOUT_MS=120000     # per-request timeout
